---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'AI共創レビュー研究所', description = 'AIと人間の共創による、透明性の高い商品レビュー・比較サイト' } = Astro.props;
const year = new Date().getFullYear();

const siteOrigin = Astro.site ?? new URL('https://toknet.info');
function canonicalPath(pathname: string): string {
  if (pathname === '/') return '/';
  if (pathname.endsWith('/')) return pathname;
  if (!/\.[a-zA-Z0-9]+$/.test(pathname)) return `${pathname}/`;
  return pathname;
}
const canonicalURL = new URL(canonicalPath(Astro.url.pathname), siteOrigin).href;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
  <link rel="canonical" href={canonicalURL} />

  <!-- OGP -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="AI共創レビュー研究所" />
  <meta property="og:image" content={`${siteOrigin.origin}/og-default.png`} />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-ZGT1S0ZHPR"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-ZGT1S0ZHPR');
  </script>

  <!-- Cloudflare Web Analytics（Cloudflare Pagesデプロイ時にDashboardで有効化） -->

  <!-- 構造化データ: Organization -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "AI共創レビュー研究所",
    "url": "https://toknet.info",
    "description": "AIと人間の共創による、透明性の高い商品レビュー・比較サイト",
    "sameAs": []
  })} />
  
  <!-- 構造化データ: WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "AI共創レビュー研究所",
    "url": "https://toknet.info",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://toknet.info/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />
  
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <style is:global>
    :root {
      --color-primary: #1a73e8;
      --color-primary-dark: #1557b0;
      --color-accent: #ff6b35;
      --color-bg: #ffffff;
      --color-bg-secondary: #f8f9fa;
      --color-text: #202124;
      --color-text-secondary: #5f6368;
      --color-border: #dadce0;
      --color-pr-bg: #fff3cd;
      --color-pr-border: #ffc107;
      --font-sans: -apple-system, BlinkMacSystemFont, "Hiragino Sans", "Hiragino Kaku Gothic ProN", "Noto Sans JP", sans-serif;
      --max-width: 1200px;
      --header-height: 64px;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--font-sans); color: var(--color-text); background: var(--color-bg); line-height: 1.7; -webkit-font-smoothing: antialiased; }
    a { color: var(--color-primary); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .container { max-width: var(--max-width); margin: 0 auto; padding: 0 20px; }
    .pr-banner { background: var(--color-pr-bg); border: 1px solid var(--color-pr-border); padding: 8px 16px; font-size: 13px; color: #856404; text-align: center; }
    .header { height: var(--header-height); border-bottom: 1px solid var(--color-border); display: flex; align-items: center; position: sticky; top: 0; background: rgba(255,255,255,0.95); backdrop-filter: blur(10px); z-index: 100; }
    .header-inner { display: flex; align-items: center; justify-content: space-between; width: 100%; max-width: var(--max-width); margin: 0 auto; padding: 0 20px; }
    .site-logo { font-size: 20px; font-weight: 700; color: var(--color-text); }
    .site-logo span { color: var(--color-primary); }
    .nav-links { display: flex; gap: 24px; list-style: none; }
    .nav-links a { color: var(--color-text-secondary); font-size: 14px; font-weight: 500; }
    .nav-links a:hover { color: var(--color-primary); text-decoration: none; }
    .main { min-height: calc(100vh - var(--header-height) - 200px); padding: 40px 0; }
    .footer { background: var(--color-bg-secondary); border-top: 1px solid var(--color-border); padding: 40px 0; margin-top: 60px; }
    .footer-inner { max-width: var(--max-width); margin: 0 auto; padding: 0 20px; }
    .footer-disclaimer { font-size: 12px; color: var(--color-text-secondary); margin-top: 16px; padding: 16px; background: var(--color-bg); border-radius: 8px; border: 1px solid var(--color-border); }
    @media (max-width: 768px) { .nav-links { display: none; } }
  </style>
</head>
<body>
  <div class="pr-banner">当サイトはアフィリエイト広告（PR）を含んでいます。Amazonアソシエイトとして適格販売により収入を得ています。</div>
  <header class="header">
    <div class="header-inner">
      <a href="/" class="site-logo">AI共創<span>レビュー研究所</span></a>
      <nav>
        <ul class="nav-links">
          <li><a href="/">ホーム</a></li>
          <li><a href="/category/laptop-pc/">PC・ノート</a></li>
          <li><a href="/category/camera/">カメラ</a></li>
          <li><a href="/category/audio-headphones/">オーディオ</a></li>
          <li><a href="/category/smart-home/">スマートホーム</a></li>
          <li><a href="/category/gaming/">ゲーム</a></li>
          <li><a href="/about/">このサイトについて</a></li>
        </ul>
      </nav>
    </div>
  </header>
  <main class="main">
    <div class="container">
      <slot />
    </div>
  </main>
  <footer class="footer">
    <div class="footer-inner">
      <p style="font-size: 14px; color: var(--color-text-secondary);">&copy; {year} AI共創レビュー研究所 (toknet.info)</p>
      <div class="footer-disclaimer">
        <strong>免責事項:</strong> 当サイトの記事は生成AIを補助的に作成し、専門家が最終確認・編集しています。商品情報は公開日時点のものであり、価格・仕様は予告なく変更される場合があります。当サイトはAmazonアソシエイトとして適格販売により収入を得ています。
      </div>
    </div>
  </footer>
</body>
</html>
