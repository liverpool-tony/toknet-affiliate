---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getSortedPosts } from '../../content/utils';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getSortedPosts();
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const isRedirect = post.data.articleType === 'redirect';
const product = post.data.products?.[0];
const pageURL = new URL(`/articles/${post.slug}/`, 'https://toknet.info').href;

// ── 構造化データ: Product（商品カードがある記事すべて）──────────────
// rating が無くても Product + offers は出力可（レビュー評価は実データ時のみ）。
const productSchema = !isRedirect && product ? {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": post.data.description,
  "brand": { "@type": "Brand", "name": "AI共創レビュー研究所" },
  ...(product.amazonUrl && {
    "offers": {
      "@type": "Offer",
      "url": product.amazonUrl,
      "availability": "https://schema.org/InStock",
      "priceCurrency": "JPY",
      ...(product.price && { "price": String(product.price).replace(/[^\d.]/g, '') }),
    }
  }),
  // 実測評価がある記事のみ reviewRating を付与（ガイドライン遵守）
  ...(typeof product.rating === 'number' && {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": product.rating,
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "1",
    }
  }),
} : null;

// ── 構造化データ: Review（実測評価がある記事のみ）──────────────────
const reviewSchema = !isRedirect && product && typeof product.rating === 'number' ? {
  "@context": "https://schema.org",
  "@type": "Review",
  "name": post.data.title,
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": product.rating,
    "bestRating": "5"
  },
  "author": {
    "@type": "Organization",
    "name": "AI共創レビュー研究所"
  },
  "datePublished": post.data.pubDate.toISOString(),
  "itemReviewed": {
    "@type": "Product",
    "name": product.name,
  }
} : null;

// ── 構造化データ: FAQPage（FAQセクションがある記事すべて）──────────
// 見出しは「## よくある質問（FAQ）」「## よくある質問」の両方に対応。
// Q&A は「### Q: …」「**Q: …**」の両フォーマットをパース。
const faqSection = post.body?.match(/## よくある質問(?:（FAQ）)?\s*\n([\s\S]*?)(?=\n## |\n$)/);
let faqItems: { "@type": string; name: string; acceptedAnswer: { "@type": string; text: string } }[] = [];
if (faqSection) {
  const block = faqSection[1];
  // Format A: "### Q: 質問\nA: 回答"
  const fmtA = [...block.matchAll(/### Q:\s*(.+)\n([\s\S]*?)(?=\n### Q:|\n## |\n$)/g)].map(m => ({
    q: m[1].trim(),
    a: m[2].replace(/^A:\s*/, '').trim(),
  }));
  // Format B: "**Q: 質問**\nA: 回答"
  const fmtB = [...block.matchAll(/\*\*Q:\s*(.+?)\*\*\s*\n([\s\S]*?)(?=\n\*\*Q:|\n## |\n$)/g)].map(m => ({
    q: m[1].trim(),
    a: m[2].replace(/^A:\s*/, '').trim(),
  }));
  const raw = fmtA.length >= fmtB.length ? fmtA : fmtB;
  faqItems = raw
    .filter(x => x.q && x.a)
    .map(x => ({
      "@type": "Question",
      name: x.q,
      acceptedAnswer: { "@type": "Answer", "text": x.a },
    }));
}
const faqSchema = faqItems.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems
} : null;

// ── 構造化データ: Article（全記事）────────────────────────────────
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "mainEntityOfPage": pageURL,
  "author": {
    "@type": "Organization",
    "name": "AI共創レビュー研究所"
  },
  "publisher": {
    "@type": "Organization",
    "name": "AI共創レビュー研究所",
    "logo": { "@type": "ImageObject", "url": "https://toknet.info/og-default.png" }
  },
  "image": "https://toknet.info/og-default.png",
  "datePublished": post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { "dateModified": post.data.updatedDate.toISOString() }),
};
---

<ArticleLayout title={`${post.data.title} | AI共創レビュー研究所`} description={post.data.description}>

  <!-- 構造化データ -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {productSchema && <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />}
  {reviewSchema && <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />}
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <!-- パンくずリスト -->
  <nav style="font-size: 13px; color: var(--color-text-secondary); margin-bottom: 24px;">
    <a href="/">ホーム</a> &gt;
    <a href={`/category/${post.data.category}/`}>{post.data.category}</a> &gt;
    <span>{post.data.title}</span>
  </nav>

  <!-- 記事先頭 -->
  <header style="margin-bottom: 32px;">
    <div style="display: flex; gap: 8px; margin-bottom: 12px;">
      <span style="background: var(--color-primary); color: white; padding: 4px 12px; border-radius: 4px; font-size: 12px; font-weight: 500;">
        {post.data.category}
      </span>
      <span style="background: var(--color-bg-secondary); color: var(--color-text-secondary); padding: 4px 12px; border-radius: 4px; font-size: 12px;">
        {post.data.articleType === 'review' ? 'レビュー' : post.data.articleType === 'comparison' ? '比較' : post.data.articleType === 'ranking' ? 'ランキング' : 'ガイド'}
      </span>
    </div>
    
    <h1 style="font-size: 28px; font-weight: 700; line-height: 1.4; margin-bottom: 16px;">
      {post.data.title}
    </h1>
    
    <div style="display: flex; gap: 16px; align-items: center; font-size: 13px; color: var(--color-text-secondary);">
      <span>📅 {new Date(post.data.pubDate).toLocaleDateString('ja-JP')} 公開</span>
      {post.data.updatedDate && (
        <span>🔄 {new Date(post.data.updatedDate).toLocaleDateString('ja-JP')} 更新</span>
      )}
    </div>

    <!-- AI表記 -->
    {post.data.aiAssisted && (
      <div style="margin-top: 16px; font-size: 13px; color: var(--color-text-secondary); padding: 8px 12px; background: var(--color-bg-secondary); border-radius: 6px; display: inline-block;">
        🤖 この記事は生成AIを補助的に活用して作成しています。内容は編集部が確認・編集のうえ公開しています。
      </div>
    )}
  </header>

  <!-- 商品情報カード -->
  {product && (
    <div style="border: 1px solid var(--color-border); border-radius: 12px; padding: 24px; margin-bottom: 32px; background: var(--color-bg-secondary);">
      <div style="display: flex; gap: 20px; align-items: flex-start;">
        <div style="flex: 1;">
          <h3 style="font-size: 18px; font-weight: 600; margin-bottom: 8px;">{product.name}</h3>
          {product.rating && (
            <div style="margin-bottom: 8px;">
              <span style="color: var(--color-accent); font-size: 18px;">⭐</span>
              <span style="font-size: 18px; font-weight: 600;">{product.rating}</span>
              <span style="color: var(--color-text-secondary);"> / 5.0</span>
            </div>
          )}
          {product.price && (
            <p style="font-size: 14px; color: var(--color-text-secondary); margin-bottom: 12px;">
              参考価格: <strong>{product.price}円</strong>
            </p>
          )}
          {product.amazonUrl && (
            <a href={product.amazonUrl} target="_blank" rel="noopener noreferrer sponsored" style="display: inline-block; background: #ff9900; color: white; padding: 12px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; text-decoration: none;">
              🛒 Amazonで見る
            </a>
          )}
        </div>
      </div>
    </div>
  )}

  <!-- 記事本文 -->
  <article style="max-width: 720px;">
    <Content />
  </article>

  <!-- 関連記事 -->
  <section style="margin-top: 60px; padding-top: 32px; border-top: 1px solid var(--color-border);">
    <h3 style="font-size: 18px; font-weight: 600; margin-bottom: 16px;">関連記事</h3>
    <div style="display: grid; gap: 16px;">
      {(await getSortedPosts()).filter(p => p.data.category === post.data.category && p.slug !== post.slug).slice(0, 3).map(related => (
        <a href={`/articles/${related.slug}/`} style="display: flex; gap: 12px; padding: 16px; border: 1px solid var(--color-border); border-radius: 8px; text-decoration: none; color: inherit; transition: box-shadow 0.2s;">
          <div style="flex: 1;">
            <h4 style="font-size: 14px; font-weight: 600; margin-bottom: 4px;">{related.data.title}</h4>
            <p style="font-size: 12px; color: var(--color-text-secondary);">{related.data.description?.slice(0, 80)}...</p>
          </div>
          {related.data.products?.[0]?.rating && (
            <span style="font-size: 12px; color: var(--color-accent); white-space: nowrap;">⭐ {related.data.products[0].rating}</span>
          )}
        </a>
      ))}
    </div>
  </section>

</ArticleLayout>
